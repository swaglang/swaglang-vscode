{
  "name": "swaglang-vscode",
  "displayName": "SwagLang",
  "description": "SwagLang language support for Visual Studio Code",
  "version": "0.1.0",
  "publisher": "swaglang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "swaglang",
        "aliases": [
          "SwagLang",
          "swaglang"
        ],
        "extensions": [
          ".swag"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "swaglang",
        "scopeName": "source.swag",
        "path": "./syntaxes/swaglang.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "SwagLang",
      "properties": {
        "swaglang.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python executable. Leave empty to use 'python3' (or 'python' on Windows) from PATH."
        }
      }
    }
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
