{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SwagLang",
  "scopeName": "source.swag",
  "fileTypes": ["swag"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#function-decl" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.swaglang",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.swaglang",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.swaglang",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.swaglang",
          "match": "\\\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.swaglang",
          "match": "\\b(if|else|while|for|do|in|break|continue|return|defer)\\b"
        },
        {
          "name": "keyword.declaration.swaglang",
          "match": "\\b(interface|extends|void)\\b"
        },
        {
          "name": "storage.modifier.swaglang",
          "match": "\\b(let|const)\\b"
        },
        {
          "name": "constant.language.swaglang",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "name": "support.type.swaglang",
      "match": "\\b(int|float|string|bool|error|map|set)\\b"
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.float.swaglang",
          "match": "\\b[0-9]*\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.swaglang",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.swaglang",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.comparison.swaglang",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.swaglang",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.swaglang",
          "match": "\\*\\*|\\+\\+|--|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.ternary.swaglang",
          "match": "\\?"
        }
      ]
    },
    "function-decl": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\(.*\\)\\s*(->|\\{|:))",
      "captures": {
        "1": { "name": "entity.name.function.swaglang" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.swaglang" }
      }
    },
    "identifiers": {
      "name": "variable.other.swaglang",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
